KIITEC_SYNC_URL=https://YOUR-APP-DOMAIN/api/public/connector/sync

# Generate this token in the dashboard (Router/Settings → regenerate connector token)
KIITEC_CONNECTOR_TOKEN=replace-with-your-connector-token

MIKROTIK_HOST=192.168.10.1
MIKROTIK_PORT=8728
MIKROTIK_USER=connector
MIKROTIK_PASSWORD=replace-with-your-mikrotik-password
MIKROTIK_USE_TLS=false

KIITEC_INTERVAL_SECONDS=20
